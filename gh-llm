#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v uv >/dev/null 2>&1; then
  echo "error: uv is required to run this extension. Install from https://docs.astral.sh/uv/" >&2
  exit 1
fi

export GH_LLM_DISPLAY_CMD="gh llm"
exec uv run --project "${SCRIPT_DIR}" gh-llm "$@"
